# Backend Environment Variables
# Copy this file to .env for local development

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# OpenAI API (required)
OPENAI_API_KEY=your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_DIMENSION=1536

# Environment
ENVIRONMENT=development
DEBUG=false

# CORS (comma-separated list of allowed origins)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001

# API key (recommended for any public deployment; empty = open).
# When set, every /api/v1/* route except health/metrics requires
# `Authorization: Bearer <key>` or `X-API-Key: <key>`. Pass the same value as
# BACKEND_API_KEY on the frontend proxy so only the trusted frontend can reach
# the backend. A production start with this empty logs a warning. See docs/HARDENING.md.
API_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Redis (optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Request Limits
MAX_INGEST_PAYLOAD_SIZE=10485760
MAX_QUERY_LENGTH=5000
MAX_CONTEXT_CHARS=50000
MAX_CONTEXT_TOKENS=12000

# OpenAI API Settings
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

# Server Configuration
HOST=0.0.0.0
PORT=8000
