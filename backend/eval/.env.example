# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# OpenAI (required)
OPENAI_API_KEY=your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4-turbo-preview
EMBEDDING_DIMENSION=1536

# Optional: OpenAI API settings
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

# Optional: Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Optional: CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: Request limits
MAX_INGEST_PAYLOAD_SIZE=10485760
MAX_QUERY_LENGTH=5000
MAX_CONTEXT_CHARS=50000
MAX_CONTEXT_TOKENS=12000

# Optional: Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Optional: Environment
ENVIRONMENT=development
DEBUG=false

# Eval harness (eval/run_eval.py)
# EVAL_PERSIST_RUNS=true — write eval_runs / eval_case_results after each run (default on)
# EVAL_RECORD_CHAT=false — also append eval turns to a chat thread (optional)
# EVAL_MAX_CASES= — optional positive int to truncate dataset
# EVAL_USE_LLM_JUDGE=false
