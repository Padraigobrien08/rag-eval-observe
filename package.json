{
  "name": "rag-eval-observability",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "dev:clean": "pnpm clean && pnpm dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "demo:e2e": "pnpm build && playwright test e2e/demo-automated.spec.ts",
    "demo:capture": "CAPTURE_README_DEMO=1 pnpm build && CAPTURE_README_DEMO=1 pnpm exec playwright test e2e/readme-demo-capture.spec.ts",
    "demo:gif": "bash scripts/stitch-demo-gif.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed:corpus": "cd backend && uv run python scripts/seed_eval_corpus.py",
    "ingest:samples": "tsx scripts/ingest-sample-docs.ts",
    "docs:list": "tsx scripts/list-documents.ts",
    "docs:cleanup": "tsx scripts/cleanup-documents.ts"
  },
