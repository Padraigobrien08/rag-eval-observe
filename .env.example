# Environment variables for local runs.
#   - Docker Compose:  cp .env.example .env       (compose reads .env)
#   - Next.js dev:     cp .env.example .env.local (Next reads .env.local)

# OpenAI API key (required) — used by the FastAPI backend for embeddings + chat.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Backend API URL (server-side only, accessed via proxy) — the FastAPI origin.
# For Vercel deployment, set this in Vercel environment variables.
# (Legacy AZURE_API_BASE_URL is still read as a fallback for older deployments.)
BACKEND_API_BASE_URL=http://localhost:8000

# Gate the backend behind the proxy (recommended for any public deployment).
# Set the SAME value as the backend's API_KEY; the Next.js proxy forwards it as
# `X-API-Key` so direct hits to the FastAPI origin are rejected. Leave empty for
# local dev. Server-side only — never expose as NEXT_PUBLIC_*. See docs/HARDENING.md.
BACKEND_API_KEY=

# Optional: the FastAPI app also loads this file after backend/.env (see backend/app/core/config.py).
# You can put OPENAI_* or DATABASE_URL here for convenience; backend/.env overrides on conflicts.

# --- Auth.js (chat auth) ---
# Generate with: openssl rand -base64 32   (or `npx auth secret`)
AUTH_SECRET=replace-me-with-a-random-32-byte-secret

# --- Drizzle / Next.js Postgres ---
# Chat + auth tables live in the SAME database the FastAPI backend uses (ragdb).
# POSTGRES_URL is preferred; falls back to DATABASE_URL, then the local default.
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/ragdb
