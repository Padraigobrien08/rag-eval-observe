# Frontend Environment Variables
# Copy this file to .env.local for local development

# Backend API URL (server-side only, accessed via proxy)
# For Vercel deployment, set this in Vercel environment variables
AZURE_API_BASE_URL=http://localhost:8000

# Optional: the FastAPI app also loads this file after backend/.env (see backend/app/core/config.py).
# You can put OPENAI_* or DATABASE_URL here for convenience; backend/.env overrides on conflicts.

# --- Auth.js (chat auth) ---
# Generate with: openssl rand -base64 32   (or `npx auth secret`)
AUTH_SECRET=replace-me-with-a-random-32-byte-secret

# --- Drizzle / Next.js Postgres ---
# Chat + auth tables live in the SAME database the FastAPI backend uses (ragdb).
# POSTGRES_URL is preferred; falls back to DATABASE_URL, then the local default.
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/ragdb
