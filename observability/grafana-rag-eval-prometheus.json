{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum by (route) (http_requests_total)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "HTTP requests by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum by (route) (http_request_duration_ms_sum) / sum by (route) (http_requests_total)",
          "legendFormat": "{{route}} avg ms",
          "refId": "A"
        }
      ],
      "title": "Avg latency by route (approx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "expr": "openai_tokens_chat_total_tokens", "legendFormat": "chat total", "refId": "A" },
        {
          "expr": "openai_tokens_embedding_total_tokens",
          "legendFormat": "embedding total",
          "refId": "B"
        }
      ],
      "title": "OpenAI token counters (process lifetime)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "p95 request latency per route, from the http_request_latency_ms histogram.",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_latency_ms_bucket[5m])))",
          "legendFormat": "{{route}} p95",
          "refId": "A"
        }
      ],
      "title": "p95 latency by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "p95 latency per RAG pipeline stage (retrieve, embedding, chat_completion, ...), from rag_stage_latency_ms.",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(rag_stage_latency_ms_bucket[5m])))",
          "legendFormat": "{{stage}} p95",
          "refId": "A"
        }
      ],
      "title": "RAG stage p95 latency",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["rag-eval"],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "RAG Eval — API (Prometheus scrape)",
  "uid": "rag-eval-api",
  "version": 1
}
